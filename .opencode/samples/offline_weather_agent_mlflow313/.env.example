MLFLOW_TRACKING_URI=http://127.0.0.1:5013
MLFLOW_EXPERIMENT_NAME=offline-weather-agent-313

# ollama: 로컬 Ollama의 OpenAI-compatible endpoint를 사용한다.
# openai: OpenAI API 또는 사내 OpenAI-compatible gateway를 사용한다.
LLM_PROVIDER=ollama

LOCAL_QWEN_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_QWEN_API_KEY=ollama
WEATHER_AGENT_MODEL=qwen2.5-coder:14b

# LLM_PROVIDER=openai 일 때 사용한다. 모델명은 Qwen gateway 모델명을 넣어도 된다.
# 폐쇄망에서는 https://api.openai.com 대신 사내 gateway 주소를 넣는다.
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=qwen2.5-coder:14b

WEATHER_AGENT_USER_ID=offline-user
WEATHER_AGENT_SESSION_ID=offline-weather-313-session
