# Copy this file to .env and fill in only the provider you use.

# OpenCode model selection.
# For local Qwen through Ollama, use: ollama/qwen2.5-coder:14b
# For local Qwen through an OpenAI-compatible server, use: local-qwen/<model-id>
OPENCODE_MODEL=ollama/qwen2.5-coder:14b

# Local Qwen endpoint.
# Ollama default: http://localhost:11434/v1
# LM Studio default: http://127.0.0.1:1234/v1
# llama.cpp default is often: http://127.0.0.1:8080/v1
LOCAL_QWEN_BASE_URL=http://localhost:11434/v1
LOCAL_QWEN_API_KEY=ollama

# Weather agent tracing sample.
MLFLOW_TRACKING_URI=http://127.0.0.1:5001
MLFLOW_EXPERIMENT_NAME=weather-agent
WEATHER_AGENT_MODEL=qwen2.5-coder:14b
WEATHER_AGENT_USER_ID=local-user
WEATHER_AGENT_SESSION_ID=weather-demo-session
