{
  "$schema": "https://opencode.ai/config.json",
  "model": "{env:OPENCODE_MODEL}",
  "provider": {
    "local-qwen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local Qwen",
      "options": {
        "baseURL": "{env:LOCAL_QWEN_BASE_URL}",
        "apiKey": "{env:LOCAL_QWEN_API_KEY}"
      },
      "models": {
        "qwen2.5-coder:14b": {
          "name": "Qwen2.5 Coder 14B"
        },
        "qwen2.5-coder:32b": {
          "name": "Qwen2.5 Coder 32B"
        },
        "qwen3:latest": {
          "name": "Qwen3"
        },
        "qwen:7b": {
          "name": "Qwen 7B"
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "qwen2.5-coder:14b": {
          "name": "Qwen2.5 Coder 14B"
        },
        "qwen2.5-coder:32b": {
          "name": "Qwen2.5 Coder 32B"
        },
        "qwen3:latest": {
          "name": "Qwen3"
        },
        "qwen:7b": {
          "name": "Qwen 7B"
        }
      }
    }
  }
}
